# --- API ---
NODE_ENV=development
API_PORT=4000
LOG_LEVEL=info
# Base58-encoded Solana wallet secret key (KEEP SECRET — never commit a real one).
PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY
# --- Solana ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Example with API key (do NOT commit a real key):
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# --- Jupiter Swap V2 (https://dev.jup.ag/docs/api/swap-api) ---
# api.jup.ag requires an API key from https://portal.jup.ag/
JUPITER_BASE_URL=https://api.jup.ag
JUPITER_API_KEY=
JUPITER_TIMEOUT_MS=15000
JUPITER_MAX_RETRIES=3
# --- Rate limiting / circuit breaker ---
RATE_LIMIT_POINTS=30
RATE_LIMIT_DURATION_SEC=60
CIRCUIT_TIMEOUT_MS=15000
CIRCUIT_ERROR_THRESHOLD_PCT=50
CIRCUIT_RESET_MS=30000
# --- Redis (optional, for distributed rate-limit + pubsub) ---
REDIS_URL=
# --- Postgres (optional audit log) ---
DATABASE_URL=
# --- GenAI ---
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# --- Web ---
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
